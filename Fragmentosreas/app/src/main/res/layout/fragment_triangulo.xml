<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".Triangulo">

    <TextView
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        android:layout_gravity="center"
        android:textSize="30sp"
        android:layout_marginTop="60dp"
        android:text="Triángulo" />

    <EditText
        android:id="@+id/num1"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:hint="Base (Ancho)"
        android:inputType="numberDecimal"
        android:layout_marginTop="10dp"
        android:layout_gravity="center" />

    <EditText
        android:id="@+id/num2"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:hint="Altura (Alto)"
        android:inputType="numberDecimal"
        android:layout_marginTop="10dp"
        android:layout_gravity="center" />

    <Button
        android:id="@+id/botonc"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Calcular"
        android:layout_gravity="center"
        android:backgroundTint="#4D3CA0"
        android:layout_marginTop="10dp" />

    <TextView
        android:id="@+id/vista"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        android:layout_gravity="center"
        android:textSize="20sp"
        android:layout_marginTop="10dp"
        android:text="Resultado" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="bottom"
        android:layout_marginBottom="30dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/botons"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Cuadrado"
            android:layout_marginLeft="3dp"
            android:backgroundTint="#A60000" />

        <Button
            android:id="@+id/botonr"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Rectángulo"
            android:backgroundTint="#FF9800" />

        <Button
            android:id="@+id/botont"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Triángulo"
            android:backgroundTint="#2196F3" />
    </LinearLayout>
</LinearLayout>